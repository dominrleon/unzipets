generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model AdminUser {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Plush {
  id                   String   @id @default(cuid())
  name                 String
  slug                 String   @unique
  imageUrl             String?
  age                  Int?
  birthDate            String?
  race                 String?
  origin               String?
  identificationNumber String?
  isActive             Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  cases                Case[]
}

model Case {
  id              String      @id @default(cuid())
  plushId         String
  title           String
  slug            String      @unique
  language        String      @default("en")
  status          CaseStatus  @default(DRAFT)
  fileNumber      String?
  caseDate        String?
  deathDate       String?
  deathPlace      String?
  causeOfDeath    String?
  investigationText String?
  startNodeId     String?     @unique
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  plush           Plush         @relation(fields: [plushId], references: [id], onDelete: Cascade)
  startNode       DecisionNode? @relation("CaseStartNode", fields: [startNodeId], references: [id], onDelete: SetNull)
  nodes           DecisionNode[]
  scans           ScanLog[]
}

model DecisionNode {
  id           String      @id @default(cuid())
  caseId        String
  type         NodeType
  internalKey  String
  title        String?
  content      String?
  videoUrl     String?
  sortOrder    Int         @default(0)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  case         Case             @relation(fields: [caseId], references: [id], onDelete: Cascade)
  answers      DecisionAnswer[] @relation("NodeAnswers")
  previousFrom DecisionAnswer[] @relation("AnswerNextNode")
  startForCase Case? @relation("CaseStartNode")

  @@unique([caseId, internalKey])
}

model DecisionAnswer {
  id         String   @id @default(cuid())
  nodeId      String
  label      String
  value      String?
  nextNodeId String
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  node       DecisionNode @relation("NodeAnswers", fields: [nodeId], references: [id], onDelete: Cascade)
  nextNode   DecisionNode @relation("AnswerNextNode", fields: [nextNodeId], references: [id], onDelete: Restrict)
}

model ScanLog {
  id         String   @id @default(cuid())
  caseId      String
  startedAt   DateTime @default(now())
  finishedAt  DateTime?
  finalNodeId String?
  sessionId   String?

  case        Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
}

enum CaseStatus {
  DRAFT
  PUBLISHED
}

enum NodeType {
  QUESTION
  ENDING
}